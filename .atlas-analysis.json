  "keyFeatures": [
    "WireGuard and quantum-resistant tunnels with DAITA support",
    "Multi-platform support (Windows, macOS, Linux, Android, iOS)",
    "WireGuard multihop and multiple obfuscation protocols (TCP, Shadowsocks, QUIC, LWO)",
    "Split tunneling with per-app and per-process exclusions",
    "Custom DNS and content blockers (ads, trackers, malware)",
    "Strict leak protection with firewall integration",
    "Kill switch functionality and lockdown mode",
    "Local network access control",
    "Device and account management",
    "Externally audited security"
  ],
  "publicApiSurface": [
    "mullvad connect - Connect to VPN tunnel",
    "mullvad disconnect - Disconnect from VPN tunnel",
    "mullvad status - Get current tunnel state",
    "mullvad account - Manage account (login, logout, create)",
    "mullvad relay set - Configure relay settings and constraints",
    "mullvad tunnel - Configure tunnel settings (WireGuard, quantum-resistant, DAITA)",
    "mullvad dns - Configure custom DNS servers",
    "mullvad split-tunnel - Configure split tunneling",
    "mullvad lockdown-mode - Enable/disable lockdown mode",
    "mullvad auto-connect - Configure auto-connect behavior",
    "mullvad lan - Configure local network access",
    "mullvad custom-list - Manage custom relay lists",
    "ManagementService gRPC API - Complete daemon control interface",
    "Desktop GUI (Electron) - Graphical user interface",
    "Android VPN Service - Android VPN integration",
    "iOS Network Extension - iOS VPN integration"
  ]
